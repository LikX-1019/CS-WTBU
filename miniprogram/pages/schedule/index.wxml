<view class="mini-page schedule-page">
  <view class="custom-nav" style="{{navStyle}}">
    <view class="custom-nav-title">课表</view>
  </view>

  <view class="content schedule-content">
    <view class="schedule-filters">
      <picker
        class="filter-picker semester-picker"
        mode="selector"
        range="{{semesterOptions}}"
        range-key="label"
        value="{{semesterIndex}}"
        bindchange="onSemesterChange"
      >
        <view class="filter-select">
          <text>{{selectedSemesterLabel}}</text>
          <view class="chevron-down"></view>
        </view>
      </picker>
      <picker
        class="filter-picker week-picker"
        mode="selector"
        range="{{weekOptions}}"
        value="{{weekIndex}}"
        bindchange="onWeekChange"
      >
        <view class="filter-select">
          <text>第{{currentWeek}}周</text>
          <view class="chevron-down"></view>
        </view>
      </picker>
    </view>

    <view wx:if="{{loading}}" class="soft-card state-card">正在从教务系统加载课表...</view>
    <view wx:elif="{{errorText}}" class="soft-card state-card state-error">{{errorText}}</view>

    <view wx:if="{{!errorText && currentSchedule}}" class="soft-card term-week-card {{termWeekConfig ? 'term-week-locked' : ''}}">
      <view class="term-week-head">
        <view>
          <view class="term-week-title">{{termWeekConfig ? '学期起始周已配置' : '补充学期起始周'}}</view>
          <view class="term-week-subtitle">{{termWeekProgressText}}</view>
        </view>
        <view wx:if="{{termWeekConfig}}" class="term-week-badge">{{termWeekConfig.sourceText}}</view>
      </view>
      <view wx:if="{{canSubmitTermWeekReport}}" class="term-week-form">
        <picker mode="date" value="{{reportWeekMondayDate}}" bindchange="onReportDateChange">
          <view class="term-week-input">{{reportWeekMondayDate}}</view>
        </picker>
        <picker mode="selector" range="{{weekOptions}}" value="{{reportWeekIndex}}" bindchange="onReportWeekChange">
          <view class="term-week-input">第{{reportWeekNumber}}周</view>
        </picker>
        <button class="term-week-button" loading="{{submittingTermWeek}}" disabled="{{submittingTermWeek}}" bindtap="submitTermWeekReport">
          上报
        </button>
      </view>
      <view wx:elif="{{termWeekReport && !termWeekConfig}}" class="term-week-note">
        已上报：{{termWeekReport.weekMondayDate}} · 第{{termWeekReport.weekNumber}}周
      </view>
    </view>

    <view
      class="timetable"
      bindtouchstart="onScheduleTouchStart"
      bindtouchend="onScheduleTouchEnd"
    >
      <view
        wx:for="{{days}}"
        wx:key="week"
        class="weekday"
        style="{{item.style}}"
      >
        <view class="weekday-name">{{item.week}}</view>
        <view class="weekday-date">{{item.date}}</view>
      </view>

      <view
        wx:for="{{periods}}"
        wx:key="index"
        class="time-cell"
        style="{{item.style}}"
      >
        <view class="period-index">{{item.index}}</view>
        <view>{{item.start}}</view>
        <view>{{item.end}}</view>
      </view>

      <view
        wx:for="{{lessons}}"
        wx:key="id"
        class="lesson-block lesson-{{item.tone}}"
        style="{{item.style}}"
        data-index="{{index}}"
        bindtap="openLessonDetail"
      >
        <block wx:for="{{item.nameLines}}" wx:key="*this" wx:for-item="line">
          <view>{{line}}</view>
        </block>
        <view class="lesson-room">{{item.room}}</view>
      </view>
    </view>

    <view wx:if="{{!loading && lessons.length === 0}}" class="soft-card state-card empty-schedule">暂无课表数据</view>
  </view>

  <view class="tabbar">
    <view class="tab" bindtap="goHome">
      <view class="tab-icon icon-home"></view>
      <text>首页</text>
    </view>
    <view class="tab tab-active" bindtap="goSchedule">
      <view class="tab-icon icon-calendar"></view>
      <text>课表</text>
    </view>
    <view class="tab" bindtap="goGrades">
      <view class="tab-icon icon-score"></view>
      <text>成绩</text>
    </view>
    <view class="tab" bindtap="goProfile">
      <view class="tab-icon icon-user"></view>
      <text>个人</text>
    </view>
  </view>

  <view wx:if="{{lessonDetailVisible}}" class="lesson-detail-mask" bindtap="closeLessonDetail">
    <view class="lesson-detail-card lesson-detail-{{selectedLesson.tone}}" catchtap="noop">
      <view class="lesson-detail-head">
        <view>
          <view class="lesson-detail-kicker">{{selectedLesson.weekdayText}} {{selectedLesson.section}}</view>
          <view class="lesson-detail-title">{{selectedLesson.name}}</view>
        </view>
        <view class="lesson-detail-close" bindtap="closeLessonDetail"></view>
      </view>
      <view class="lesson-detail-time">{{selectedLesson.time}}</view>
      <view class="lesson-detail-list">
        <view wx:for="{{selectedLesson.detailRows}}" wx:key="label" class="lesson-detail-row">
          <text>{{item.label}}</text>
          <text>{{item.value}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
