.login-page {
  padding-top: 88rpx;
}

.title {
  color: #111827;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.2;
}

.subtitle {
  margin-top: 16rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.form-panel {
  margin-top: 48rpx;
}

.field + .field {
  margin-top: 28rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: #374151;
  font-size: 28rpx;
  font-weight: 600;
}

.input {
  box-sizing: border-box;
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  background: #ffffff;
  color: #111827;
  font-size: 30rpx;
}

.note {
  margin-top: 28rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
}
