<view class="mini-page sub-page admin-page">
  <view class="custom-nav" style="{{navStyle}}">
    <view class="nav-back" bindtap="goBack"></view>
    <view class="custom-nav-title">管理员</view>
  </view>

  <view class="content admin-content">
    <view class="admin-hero">
      <view>
        <view class="hero-title">后台总览</view>
        <view class="hero-subtitle">{{adminText || '仅管理员可查看数据'}}</view>
      </view>
      <button class="refresh-button" loading="{{loading}}" disabled="{{loading}}" bindtap="refreshDashboard">
        刷新
      </button>
    </view>

    <view wx:if="{{errorText}}" class="soft-card state-card state-error">{{errorText}}</view>
    <view wx:elif="{{loading && users.length === 0 && feedback.length === 0}}" class="soft-card state-card">
      正在读取后台数据...
    </view>

    <view wx:if="{{!errorText}}" class="stat-grid">
      <view wx:for="{{stats}}" wx:key="key" class="soft-card stat-card">
        <view class="stat-value">{{item.value}}</view>
        <view class="stat-label">{{item.label}}</view>
      </view>
    </view>

    <view wx:if="{{!errorText}}" class="segment">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="segment-item {{activeTab === item.key ? 'segment-active' : ''}}"
        data-key="{{item.key}}"
        bindtap="switchTab"
      >
        {{item.label}}
      </view>
    </view>

    <view wx:if="{{!errorText && activeTab === 'users'}}" class="list-panel">
      <view wx:if="{{users.length === 0 && !loading}}" class="soft-card empty-card">暂无绑定用户</view>
      <view wx:for="{{users}}" wx:key="id" class="soft-card user-card">
        <view class="card-top">
          <view>
            <view class="item-title">{{item.name}}</view>
            <view class="item-subtitle">{{item.studentId}} · {{item.schoolName || '未知学校'}}</view>
          </view>
          <view class="status-pill">已绑定</view>
        </view>
        <view class="detail-row">
          <text>专业班级</text>
          <text>{{item.majorText}}</text>
        </view>
        <view class="detail-row">
          <text>缓存概况</text>
          <text>{{item.cacheText}}</text>
        </view>
        <view class="detail-row">
          <text>最近更新</text>
          <text>{{item.lastFetchedText || item.updatedText || '暂无记录'}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{!errorText && activeTab === 'feedback'}}" class="list-panel">
      <view wx:if="{{feedback.length === 0 && !loading}}" class="soft-card empty-card">暂无反馈记录</view>
      <view wx:for="{{feedback}}" wx:key="id" class="soft-card feedback-item">
        <view class="card-top">
          <view>
            <view class="item-title">{{item.type}}</view>
            <view class="item-subtitle">{{item.userText || '匿名用户'}} · {{item.createdText || '刚刚'}}</view>
          </view>
          <picker
            mode="selector"
            range="{{statusOptions}}"
            value="{{item.statusIndex || 0}}"
            data-id="{{item.id}}"
            disabled="{{updatingId === item.id}}"
            bindchange="onStatusChange"
          >
            <view class="status-picker status-{{item.status}}">
              {{updatingId === item.id ? '更新中' : item.statusText}}
            </view>
          </picker>
        </view>
        <view class="feedback-content">{{item.content}}</view>
        <view wx:if="{{item.contact}}" class="contact-row">联系方式：{{item.contact}}</view>
      </view>
    </view>

    <view wx:if="{{!errorText && activeTab === 'campus'}}" class="list-panel">
      <view class="campus-intro">
        <view class="campus-intro-title">学期起始周配置</view>
        <view class="campus-intro-text">点击下方学期卡片即可编辑。先选择“当前是第几周”，再选择该周对应的周一日期，系统会自动换算出学期第 1 周。</view>
      </view>
      <view wx:if="{{termWeekSchoolGroups.length === 0 && !campusLoading}}" class="soft-card empty-card">暂无可配置学期</view>
      <view wx:for="{{termWeekSchoolGroups}}" wx:key="schoolId" class="soft-card campus-school-card">
        <view class="campus-school-head">
          <view class="campus-school-name">{{item.schoolName}}</view>
          <view class="campus-school-count">{{item.semesters.length}} 个学期</view>
        </view>
        <view class="campus-term-list">
          <view
            wx:for="{{item.semesters}}"
            wx:key="semesterId"
            wx:for-item="semester"
            class="campus-term-card {{semester.saving ? 'campus-term-card-saving' : ''}}"
            data-school-id="{{semester.schoolId}}"
            data-school-name="{{semester.schoolName}}"
            data-semester-id="{{semester.semesterId}}"
            data-term="{{semester.term}}"
            data-label="{{semester.label}}"
            data-week-number="{{semester.weekNumber}}"
            data-week-monday-date="{{semester.weekMondayDate}}"
            data-term-start-date="{{semester.termStartDate}}"
            bindtap="openTermWeekEditor"
          >
            <view class="campus-term-top">
              <view class="campus-term-copy">
                <view class="campus-term-title">{{semester.label}}</view>
                <view class="campus-term-id">学期 ID：{{semester.semesterId}}</view>
              </view>
              <view class="campus-term-state {{semester.termStartDate ? 'campus-term-state-ready' : 'campus-term-state-pending'}}">
                {{semester.saving ? '保存中' : (semester.termStartDate ? '已配置' : '待配置')}}
              </view>
            </view>
            <view
              class="campus-term-main {{semester.termStartDate ? '' : 'campus-term-main-empty'}}"
            >
              {{semester.termStartDate || '尚未设置学期第 1 周'}}
            </view>
            <view class="campus-term-foot">
              <view class="campus-term-foot-text">
                {{semester.weekMondayDate ? ('当前参考：第' + semester.weekNumber + '周 · ' + semester.weekMondayDate) : '点击设置当前周次与对应周一'}}
              </view>
              <view class="campus-term-arrow"></view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{termWeekEditorVisible}}" class="term-week-editor-mask" bindtap="closeTermWeekEditor">
    <view class="term-week-editor-panel" catchtap="noop">
      <view class="term-week-editor-head">
        <view>
          <view class="term-week-editor-kicker">{{configSchoolName}}</view>
          <view class="term-week-editor-title">{{configSemesterName}}</view>
        </view>
        <view class="term-week-editor-close" bindtap="closeTermWeekEditor">×</view>
      </view>
      <view class="term-week-editor-tip">先选择“当前是第几周”，再选择这一周对应的周一日期。</view>
      <view class="term-week-editor-grid">
        <picker mode="selector" range="{{weekOptions}}" value="{{configWeekIndex}}" bindchange="onConfigWeekChange">
          <view class="term-week-editor-field">第{{configWeekNumber}}周</view>
        </picker>
        <view class="term-week-editor-field" bindtap="openCalendar">{{configWeekMondayDate || '选择周一日期'}}</view>
      </view>
      <view class="term-week-editor-preview">
        <view class="term-week-editor-preview-label">将保存为学期第 1 周</view>
        <view class="term-week-editor-preview-value">{{configTermStartDatePreview || '请选择周一日期'}}</view>
      </view>
      <button class="term-week-editor-save" loading="{{savingTermWeek}}" disabled="{{savingTermWeek}}" bindtap="saveTermWeekConfig">
        保存配置
      </button>
    </view>
  </view>

  <view wx:if="{{calendarVisible}}" class="calendar-mask" bindtap="closeCalendar">
    <view class="calendar-panel" catchtap="noop">
      <view class="calendar-head">
        <view class="calendar-nav" bindtap="previousCalendarMonth">‹</view>
        <view class="calendar-title">{{calendarTitle}}</view>
        <view class="calendar-nav" bindtap="nextCalendarMonth">›</view>
      </view>
      <view class="calendar-weekdays">
        <view wx:for="{{calendarWeekdays}}" wx:key="*this">{{item}}</view>
      </view>
      <view class="calendar-grid">
        <view
          wx:for="{{calendarDays}}"
          wx:key="date"
          class="calendar-day {{item.className}}"
          data-date="{{item.date}}"
          data-disabled="{{item.disabled}}"
          bindtap="chooseCalendarDate"
        >
          {{item.day}}
        </view>
      </view>
      <view class="calendar-hint">仅可选择周一日期</view>
    </view>
  </view>
</view>
