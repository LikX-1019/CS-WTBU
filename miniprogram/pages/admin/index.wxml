<view class="mini-page sub-page admin-page">
  <view class="custom-nav" style="{{navStyle}}">
    <view class="nav-back" bindtap="goBack"></view>
    <view class="custom-nav-title">管理员</view>
  </view>

  <view class="content admin-content">
    <view class="admin-hero">
      <view>
        <view class="hero-title">后台总览</view>
        <view class="hero-subtitle">{{adminText || '仅管理员可查看数据'}}</view>
      </view>
      <button class="refresh-button" loading="{{loading}}" disabled="{{loading}}" bindtap="refreshDashboard">
        刷新
      </button>
    </view>

    <view wx:if="{{errorText}}" class="soft-card state-card state-error">{{errorText}}</view>
    <view wx:elif="{{loading && users.length === 0 && feedback.length === 0}}" class="soft-card state-card">
      正在读取后台数据...
    </view>

    <view wx:if="{{!errorText}}" class="stat-grid">
      <view wx:for="{{stats}}" wx:key="key" class="soft-card stat-card">
        <view class="stat-value">{{item.value}}</view>
        <view class="stat-label">{{item.label}}</view>
      </view>
    </view>

    <view wx:if="{{!errorText}}" class="segment">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="segment-item {{activeTab === item.key ? 'segment-active' : ''}}"
        data-key="{{item.key}}"
        bindtap="switchTab"
      >
        {{item.label}}
      </view>
    </view>

    <view wx:if="{{!errorText && activeTab === 'users'}}" class="list-panel">
      <view wx:if="{{users.length === 0 && !loading}}" class="soft-card empty-card">暂无绑定用户</view>
      <view wx:for="{{users}}" wx:key="id" class="soft-card user-card">
        <view class="card-top">
          <view>
            <view class="item-title">{{item.name}}</view>
            <view class="item-subtitle">{{item.studentId}} · {{item.schoolName || '未知学校'}}</view>
          </view>
          <view class="status-pill">已绑定</view>
        </view>
        <view class="detail-row">
          <text>专业班级</text>
          <text>{{item.majorText}}</text>
        </view>
        <view class="detail-row">
          <text>缓存概况</text>
          <text>{{item.cacheText}}</text>
        </view>
        <view class="detail-row">
          <text>最近更新</text>
          <text>{{item.lastFetchedText || item.updatedText || '暂无记录'}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{!errorText && activeTab === 'feedback'}}" class="list-panel">
      <view wx:if="{{feedback.length === 0 && !loading}}" class="soft-card empty-card">暂无反馈记录</view>
      <view wx:for="{{feedback}}" wx:key="id" class="soft-card feedback-item">
        <view class="card-top">
          <view>
            <view class="item-title">{{item.type}}</view>
            <view class="item-subtitle">{{item.userText || '匿名用户'}} · {{item.createdText || '刚刚'}}</view>
          </view>
          <picker
            mode="selector"
            range="{{statusOptions}}"
            value="{{item.statusIndex || 0}}"
            data-id="{{item.id}}"
            disabled="{{updatingId === item.id}}"
            bindchange="onStatusChange"
          >
            <view class="status-picker status-{{item.status}}">
              {{updatingId === item.id ? '更新中' : item.statusText}}
            </view>
          </picker>
        </view>
        <view class="feedback-content">{{item.content}}</view>
        <view wx:if="{{item.contact}}" class="contact-row">联系方式：{{item.contact}}</view>
      </view>
    </view>

    <view wx:if="{{!errorText && activeTab === 'campus'}}" class="list-panel">
      <view class="soft-card campus-form">
        <view class="item-title">学期起始周配置</view>
        <view class="campus-grid">
          <picker mode="selector" range="{{schools}}" range-key="name" value="{{configSchoolIndex}}" bindchange="onConfigSchoolChange">
            <view class="campus-input">{{configSchoolName || '选择学校'}}</view>
          </picker>
          <input class="campus-input" placeholder="学期 ID" value="{{configSemesterId}}" bindinput="onConfigSemesterInput" />
          <input class="campus-input campus-input-wide" placeholder="学期名称（可选）" value="{{configTerm}}" bindinput="onConfigTermInput" />
          <picker mode="date" value="{{configWeekMondayDate}}" bindchange="onConfigDateChange">
            <view class="campus-input">{{configWeekMondayDate}}</view>
          </picker>
          <picker mode="selector" range="{{weekOptions}}" value="{{configWeekIndex}}" bindchange="onConfigWeekChange">
            <view class="campus-input">第{{configWeekNumber}}周</view>
          </picker>
          <button class="campus-save" loading="{{savingTermWeek}}" disabled="{{savingTermWeek}}" bindtap="saveTermWeekConfig">
            保存
          </button>
        </view>
      </view>

      <view wx:if="{{termWeekSummary}}" class="campus-summary">
        <view class="soft-card campus-summary-card">
          <view class="stat-value">{{termWeekSummary.configCount}}</view>
          <view class="stat-label">官方配置</view>
        </view>
        <view class="soft-card campus-summary-card">
          <view class="stat-value">{{termWeekSummary.reportCount}}</view>
          <view class="stat-label">用户上报</view>
        </view>
        <view class="soft-card campus-summary-card">
          <view class="stat-value">{{termWeekSummary.readyCount}}</view>
          <view class="stat-label">可聚合</view>
        </view>
      </view>

      <view wx:if="{{termWeekItems.length === 0 && !campusLoading}}" class="soft-card empty-card">暂无学期周配置</view>
      <view wx:for="{{termWeekItems}}" wx:key="id" class="soft-card term-week-admin-card">
        <view class="card-top">
          <view>
            <view class="item-title">{{item.term || item.semesterId}}</view>
            <view class="item-subtitle">{{item.schoolName}} · {{item.semesterId}}</view>
          </view>
          <view class="status-pill">{{item.config ? item.config.sourceText : '待聚合'}}</view>
        </view>
        <view class="detail-row">
          <text>起始周</text>
          <text>{{item.config ? item.config.termStartDate : '未配置'}}</text>
        </view>
        <view class="detail-row">
          <text>样本进度</text>
          <text>{{item.progress.reportCount}}/{{item.progress.targetCount}}</text>
        </view>
        <view class="detail-row">
          <text>最高票</text>
          <text>{{item.progress.winner ? item.progress.winner.termStartDate : '暂无'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
