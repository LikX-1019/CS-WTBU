.sub-page {
  padding-bottom: 48rpx;
}

.nav-back {
  position: absolute;
  left: 32rpx;
  bottom: 28rpx;
  width: 44rpx;
  height: 44rpx;
  color: #101828;
}

.nav-back::before {
  content: "";
  position: absolute;
  left: 15rpx;
  top: 10rpx;
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(45deg);
}

.admin-content {
  padding-bottom: 28rpx;
}

.admin-hero {
  min-height: 136rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 20rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #172554, #2563eb 64%, #0f766e);
  box-shadow: 0 20rpx 44rpx rgba(37, 99, 235, 0.16);
}

.admin-hero > view {
  flex: 1;
  min-width: 0;
}

.hero-title {
  margin-bottom: 14rpx;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1;
}

.hero-subtitle {
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  line-height: 1.35;
}

.refresh-button {
  flex: 0 0 112rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 26rpx;
  line-height: 64rpx;
}

.refresh-button[disabled] {
  color: rgba(255, 255, 255, 0.72);
}

.state-card {
  min-height: 88rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #667085;
  font-size: 26rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.state-error {
  color: #e11d48;
  background: #fff1f2;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.stat-card {
  min-height: 128rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 22rpx 18rpx;
  text-align: center;
}

.stat-value {
  margin-bottom: 12rpx;
  color: #101828;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-label {
  color: #667085;
  font-size: 22rpx;
  line-height: 1.2;
}

.segment {
  height: 76rpx;
  display: flex;
  padding: 6rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #dfe5ee;
  border-radius: 14rpx;
  background: #edf2f7;
}

.segment-item {
  flex: 1;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  color: #667085;
  font-size: 26rpx;
  font-weight: 700;
}

.segment-active {
  color: #1d4ed8;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(16, 24, 40, 0.06);
}

.list-panel {
  min-height: 260rpx;
}

.user-card,
.feedback-item {
  padding: 26rpx 28rpx;
  margin-bottom: 16rpx;
}

.card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.card-top > view:first-child {
  flex: 1;
  min-width: 0;
}

.item-title {
  margin-bottom: 12rpx;
  color: #101828;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.item-subtitle {
  color: #667085;
  font-size: 24rpx;
  line-height: 1.35;
}

.status-pill,
.status-picker {
  min-width: 104rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #1d4ed8;
  background: #eef4ff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 52rpx;
  text-align: center;
  white-space: nowrap;
}

.status-processing {
  color: #0f766e;
  background: #ccfbf1;
}

.status-resolved {
  color: #15803d;
  background: #dcfce7;
}

.status-closed {
  color: #475467;
  background: #eef0f4;
}

.detail-row {
  min-height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border-top: 1rpx solid #f0f2f5;
  color: #667085;
  font-size: 24rpx;
}

.detail-row text:first-child {
  flex: 0 0 128rpx;
}

.detail-row text:last-child {
  flex: 1;
  color: #101828;
  line-height: 1.35;
  text-align: right;
  overflow-wrap: break-word;
}

.feedback-content {
  color: #101828;
  font-size: 27rpx;
  line-height: 1.55;
  overflow-wrap: break-word;
}

.contact-row {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f2f5;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.45;
}

.empty-card {
  min-height: 144rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #98a2b3;
  font-size: 26rpx;
}

.campus-intro {
  margin-bottom: 18rpx;
  padding: 6rpx 6rpx 2rpx;
}

.campus-intro-title {
  color: #101828;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.2;
}

.campus-intro-text {
  margin-top: 10rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.55;
}

.campus-school-card {
  padding: 22rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #d9e2ef;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.05);
}

.campus-school-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.campus-school-name {
  color: #101828;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.campus-school-count {
  color: #667085;
  font-size: 22rpx;
  font-weight: 700;
}

.campus-term-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.campus-term-card {
  padding: 20rpx 18rpx;
  border: 1rpx solid #d7dfeb;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #ffffff, #fbfdff);
}

.campus-term-card-saving {
  opacity: 0.72;
}

.campus-term-top,
.campus-term-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.campus-term-top {
  margin-bottom: 10rpx;
}

.campus-term-copy {
  flex: 1;
  min-width: 0;
}

.campus-term-title {
  color: #101828;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.campus-term-id,
.campus-term-foot-text {
  color: #667085;
  font-size: 21rpx;
  line-height: 1.45;
}

.campus-term-id {
  margin-top: 6rpx;
}

.campus-term-state {
  min-width: 92rpx;
  height: 48rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 48rpx;
  text-align: center;
}

.campus-term-state-ready {
  color: #166534;
  background: #dcfce7;
}

.campus-term-state-pending {
  color: #1d4ed8;
  background: #eff6ff;
}

.campus-term-main {
  margin-bottom: 10rpx;
  color: #101828;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.campus-term-main-empty {
  color: #94a3b8;
}

.campus-term-arrow {
  width: 12rpx;
  height: 12rpx;
  border-right: 3rpx solid #cbd5e1;
  border-bottom: 3rpx solid #cbd5e1;
  transform: rotate(-45deg);
}

.term-week-editor-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  display: flex;
  align-items: flex-end;
  padding: 24rpx;
  background: rgba(15, 23, 42, 0.58);
}

.term-week-editor-panel {
  width: 100%;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 28rpx 70rpx rgba(15, 23, 42, 0.26);
}

.term-week-editor-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.term-week-editor-kicker {
  color: #667085;
  font-size: 22rpx;
  line-height: 1.3;
}

.term-week-editor-title {
  margin-top: 6rpx;
  color: #101828;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.term-week-editor-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #f1f5f9;
  color: #475467;
  font-size: 36rpx;
  line-height: 56rpx;
  text-align: center;
}

.term-week-editor-tip {
  margin-top: 14rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.5;
}

.term-week-editor-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.term-week-editor-field,
.term-week-editor-save {
  min-height: 72rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.term-week-editor-field {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 18rpx;
  border: 1rpx solid #d8dee8;
  color: #101828;
  background: #f8fafc;
}

.term-week-editor-preview {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #f8fafc;
}

.term-week-editor-preview-label {
  color: #667085;
  font-size: 22rpx;
  line-height: 1.3;
}

.term-week-editor-preview-value {
  margin-top: 8rpx;
  color: #101828;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.term-week-editor-save {
  width: 100%;
  margin-top: 18rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  line-height: 72rpx;
}

.term-week-editor-save[disabled] {
  opacity: 0.68;
}

.calendar-mask {
  position: fixed;
  inset: 0;
  z-index: 120;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(15, 23, 42, 0.48);
}

.calendar-panel {
  width: 100%;
  max-width: 640rpx;
  padding: 28rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 68rpx rgba(15, 23, 42, 0.24);
}

.calendar-head {
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.calendar-title {
  color: #101828;
  font-size: 30rpx;
  font-weight: 900;
}

.calendar-nav {
  width: 68rpx;
  height: 68rpx;
  border-radius: 12rpx;
  background: #eef4ff;
  color: #1d4ed8;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 64rpx;
  text-align: center;
}

.calendar-weekdays,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.calendar-weekdays {
  margin-bottom: 10rpx;
  color: #667085;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
}

.calendar-weekdays view {
  height: 42rpx;
  line-height: 42rpx;
}

.calendar-grid {
  gap: 8rpx;
}

.calendar-day {
  height: 68rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #101828;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 68rpx;
  text-align: center;
}

.calendar-day-muted {
  color: #cbd5e1;
  background: #f8fafc;
}

.calendar-day-disabled {
  color: #cbd5e1;
}

.calendar-day-monday {
  color: #1d4ed8;
  background: #eef4ff;
}

.calendar-day-selected {
  color: #ffffff;
  background: #2563eb;
}

.calendar-hint {
  margin-top: 18rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.35;
  text-align: center;
}
