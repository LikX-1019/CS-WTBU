.profile-card {
  height: 270rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  border-radius: 18rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2f7bff, #3e89ff 62%, #2b74f2);
  box-shadow: 0 20rpx 44rpx rgba(47, 123, 255, 0.18);
  margin-bottom: 24rpx;
}

.edit-hint {
  margin: -8rpx 0 24rpx;
  color: #667085;
  font-size: 24rpx;
  text-align: center;
}

.avatar-button {
  flex: 0 0 140rpx;
  width: 140rpx;
  height: 140rpx;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 50%;
  background: transparent;
  overflow: hidden;
  line-height: 1;
}

.avatar-button::after {
  border: 0;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 50%;
  background: linear-gradient(#eef5ff 0 38%, #b7d5ff 39% 100%);
  position: relative;
  overflow: hidden;
}

.avatar-image {
  width: 140rpx;
  height: 140rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 50%;
  box-sizing: border-box;
  display: block;
}

.profile-card > view:nth-child(2) {
  flex: 1;
  min-width: 0;
  padding: 0 24rpx;
}

.avatar::before {
  content: "";
  position: absolute;
  left: 44rpx;
  top: 32rpx;
  width: 50rpx;
  height: 58rpx;
  border-radius: 48% 48% 45% 45%;
  background: #ffd2b2;
  box-shadow: 0 -22rpx 0 #1f2937;
}

.avatar::after {
  content: "";
  position: absolute;
  left: 30rpx;
  bottom: -14rpx;
  width: 80rpx;
  height: 58rpx;
  border-radius: 36rpx 36rpx 16rpx 16rpx;
  background: #2f7bff;
  border: 4rpx solid rgba(255, 255, 255, 0.74);
}

.profile-name {
  margin-bottom: 18rpx;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 800;
}

.profile-line {
  margin-bottom: 16rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1;
}

.profile-line:last-child {
  margin-bottom: 0;
}

.profile-arrow {
  flex: 0 0 18rpx;
  width: 18rpx;
  height: 18rpx;
  border-right: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: rotate(-45deg);
  opacity: 0.92;
}

.info-panel {
  padding: 2rpx 24rpx;
  margin-bottom: 20rpx;
}

.panel-title {
  margin: 26rpx 0 24rpx;
  color: #101828;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.info-row {
  min-height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #344054;
  font-size: 26rpx;
}

.info-value {
  max-width: 420rpx;
  color: #111827;
  text-align: right;
  line-height: 1.3;
}

.action-panel {
  overflow: hidden;
}

.action-row {
  height: 90rpx;
  display: flex;
  align-items: center;
  padding: 0 26rpx;
  border-bottom: 1rpx solid #eef0f4;
  color: #101828;
  font-size: 28rpx;
}

.action-row:last-child {
  border-bottom: 0;
}

.action-icon {
  flex: 0 0 36rpx;
  width: 36rpx;
  height: 36rpx;
  color: #344054;
  position: relative;
}

.action-row text {
  flex: 1;
  padding-left: 16rpx;
}

.action-settings::before {
  content: "";
  position: absolute;
  inset: 5rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  box-shadow: 0 -8rpx 0 -3rpx currentColor, 0 8rpx 0 -3rpx currentColor,
    8rpx 0 0 -3rpx currentColor, -8rpx 0 0 -3rpx currentColor;
}

.action-about::before {
  content: "i";
  position: absolute;
  inset: 2rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  text-align: center;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 30rpx;
}

.action-feedback::before {
  content: "";
  position: absolute;
  inset: 6rpx 3rpx;
  border: 3rpx solid currentColor;
  border-radius: 5rpx;
}

.action-feedback::after {
  content: "";
  position: absolute;
  left: 11rpx;
  top: 12rpx;
  width: 16rpx;
  height: 8rpx;
  border-left: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
  transform: rotate(-45deg);
}

.row-arrow {
  flex: 0 0 16rpx;
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid #98a2b3;
  border-bottom: 3rpx solid #98a2b3;
  transform: rotate(-45deg);
}

.profile-state {
  min-height: 88rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #667085;
  font-size: 26rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.profile-error {
  color: #e11d48;
  background: #fff1f2;
}

.edit-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 23, 42, 0.45);
}

.edit-panel {
  width: 100%;
  max-height: 82vh;
  padding: 28rpx 32rpx 36rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
}

.edit-head {
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.edit-title {
  color: #101828;
  font-size: 32rpx;
  font-weight: 800;
}

.edit-close {
  width: 44rpx;
  height: 44rpx;
  position: relative;
  color: #667085;
}

.edit-close::before,
.edit-close::after {
  content: "";
  position: absolute;
  left: 20rpx;
  top: 8rpx;
  width: 4rpx;
  height: 30rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.edit-close::before {
  transform: rotate(45deg);
}

.edit-close::after {
  transform: rotate(-45deg);
}

.edit-scroll {
  max-height: 56vh;
}

.edit-field {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid #eef0f4;
}

.edit-field text {
  flex: 0 0 156rpx;
  color: #344054;
  font-size: 26rpx;
}

.edit-field input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  color: #101828;
  font-size: 28rpx;
  text-align: right;
}

.edit-save {
  height: 88rpx;
  margin-top: 28rpx;
  border-radius: 12rpx;
  background: #2f7bff;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 88rpx;
}

.edit-save[disabled] {
  background: #93b4e8;
}
